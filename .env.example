# Application Configuration
APP_NAME=ANNIVERSARY-SITE
APP_ENV=development
PORT=8080
# Optional public base URL used in startup logs (for VPS/domain deployment)
# Example: https://anniversary.yourdomain.com
PUBLIC_BASE_URL=

# Anniversary App Mode
# false = run public/setup anniversary API + frontend only
# true  = enable existing admin RBAC APIs (requires DB)
ENABLE_ADMIN_API=false
ANNIVERSARY_STORE=json
ANNIVERSARY_DATA_FILE=./data/anniversary.json
TENANT_DEFAULT_SLUG=default
ANNIVERSARY_UPLOAD_MAX_MB=50

# SaaS Tenant Plan Quota (for POST /api/tenants by non-global users)
# Format: plan:limit,plan:limit
# limit >= 0 : maximum owned tenants
# limit < 0  : unlimited
SAAS_TENANT_PLAN_LIMITS=free:1,starter:2,pro:5
SAAS_TENANT_DEFAULT_PLAN=free
# Optional per-user override by user_id or email:
# SAAS_TENANT_PLAN_OVERRIDES=user-id-1:starter,user@email.com:pro
SAAS_TENANT_PLAN_OVERRIDES=

# Database Configuration
# For Docker Compose, set DB_HOST to service name (e.g. postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASS=your_password
DB_NAME=anniversary_site
DB_SSLMODE=disable

# JWT Configuration
JWT_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_EXP=24

# Google Login (ID Token verification)
# Required for POST /api/user/google/login
GOOGLE_CLIENT_ID=
# Optional: multiple audiences separated by comma (web/mobile clients)
GOOGLE_CLIENT_IDS=

# Database Migration Configuration
PATH_MIGRATE=file://migrations

# Cache Configuration (in seconds)
TTL_CACHE_CONFIG_APP=86400

# Application Config ID (Optional)
CONFIG_ID=

# Redis Configuration (for session management and rate limiting)
# For Docker Compose, set REDIS_HOST to service name (e.g. redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting Configuration
LOGIN_ATTEMPT_LIMIT=5
LOGIN_ATTEMPT_WINDOW_SECONDS=60
LOGIN_BLOCK_DURATION_SECONDS=300
REGISTER_RATE_LIMIT=5
REGISTER_RATE_WINDOW_SECONDS=60

# Storage Configuration (for file/image uploads)
# Supported providers: "minio" or "r2" (Cloudflare R2)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=uploads
STORAGE_USE_SSL=false
STORAGE_BASE_URL=http://localhost:9000
STORAGE_REGION=auto

# Cloudflare R2 Configuration (only if STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=your_cloudflare_account_id

# Logging
LOG_LEVEL=5
LOG_FORMAT=json
NODE=api

# Runtime
# Set true/1 to run migration at container startup via entrypoint
RUN_MIGRATION=false
